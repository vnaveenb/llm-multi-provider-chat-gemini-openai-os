# ── LLM Provider ─────────────────────────────────────────────────────────────
# Format: provider:model-name — change this one var to swap providers
LLM_PROVIDER=google_genai:gemini-2.0-flash

# ── Embeddings Provider ───────────────────────────────────────────────────────
# WARNING: changing this requires re-indexing all vector stores
EMBEDDINGS_PROVIDER=google_genai:models/text-embedding-004

# ── Gemini API (default provider) ────────────────────────────────────────────
GOOGLE_API_KEY=your-gemini-api-key-here

# ── Vertex AI (swap-ready — uncomment if switching to Vertex) ────────────────
# LLM_PROVIDER=google_vertexai:gemini-2.0-flash-001
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── OpenAI (swap-ready) ───────────────────────────────────────────────────────
# LLM_PROVIDER=openai:gpt-4o
# OPENAI_API_KEY=your-openai-api-key

# ── Anthropic (swap-ready) ────────────────────────────────────────────────────
# LLM_PROVIDER=anthropic:claude-opus-4-8
# ANTHROPIC_API_KEY=your-anthropic-api-key

# ── AWS Bedrock (swap-ready) ──────────────────────────────────────────────────
# LLM_PROVIDER=bedrock:anthropic.claude-3-5-sonnet-20241022-v2:0
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_DEFAULT_REGION=us-east-1

# ── Redis memory backend ──────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── LangSmith observability (optional) ───────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-api-key
# LANGCHAIN_PROJECT=portfolio-project-1
